# Orchestration LLM (NOT the model being fine-tuned)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Training limits
MAX_TRAINING_HOURS=2
CODE_EXEC_TIMEOUT=7200

# Optional tracking
WANDB_API_KEY=
MLFLOW_TRACKING_URI=